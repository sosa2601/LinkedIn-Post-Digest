    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const post = $('Filter by Date + Map Fields').item.json;\nconst scoreResp = $json;\nlet score = 0, reason = '';\ntry {\n  const c = scoreResp.choices && scoreResp.choices[0] && scoreResp.choices[0].message ? scoreResp.choices[0].message.content : '{}';\n  const m = c.match(new RegExp('{[^}]+}'));\n  const p = JSON.parse(m ? m[0] : '{}');\n  score = p.score || 0; reason = p.reason || '';\n} catch(e) { score = 0; reason = 'Parse error'; }\nreturn {\n  post_id: post.post_id,\n  'creator_name ': post.creator_name,\n  'creator_url ': post.creator_url,\n  'post_url ': post.post_url,\n  'post_text ': post.post_text,\n  'repost_text ': post.repost_text,\n  'post_type ': post.post_type,\n  'posted_date ': post.posted_date,\n  'likes ': post.likes,\n  'comments ': post.comments,\n  'shares ': post.shares,\n  relevancy_score: score,\n  relevancy_reason: reason,\n  'processed ': 'false',\n  scraped_at: new Date().toISOString()\n};"
      },
