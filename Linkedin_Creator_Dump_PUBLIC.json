        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ (function() { var vm = $json; var ctx = vm.my_context || \"{}\"; var ctxObj = {}; try { ctxObj = JSON.parse(ctx); } catch(e) {}; var ctxStr = \"Goal: \" + (ctxObj.goal||\"GTM Engineer\") + \". Interests: \" + (ctxObj.interests||\"AI, GTM, automation\") + \". Score 80+: \" + (ctxObj.score_80_plus||\"directly actionable\"); var prompt = \"Score this LinkedIn post 0-100 for relevancy. Return ONLY JSON: score and reason (max 12 words).\\n\\nPERSON: \" + ctxStr + \"\\n\\nPOST: \" + (vm.text_for_scoring||\"\") + \"\\n\\nReturn only: {\\\"score\\\": 85, \\\"reason\\\": \\\"short reason here\\\"}\"; return {\"model\":\"anthropic/claude-haiku-4-5\",\"max_tokens\":100,\"messages\":[{\"role\":\"user\",\"content\":prompt}]}; })() }}",
        "options": {}
      },
      "id": "YOUR_CREDENTIAL_ID",
      "name": "Score Relevancy via OpenRouter",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
