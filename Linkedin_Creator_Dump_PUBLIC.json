    {
      "parameters": {
        "jsCode": "const creatorMeta = $('Prepare Creators + Date Range').item.json;\nconst fromDate = new Date(creatorMeta.from_date + 'T00:00:00Z');\nconst MY_CONTEXT = {\n  name: 'Saswati Gorai',\n  role: 'GTM Engineer and AI Automation Specialist, Bangalore',\n  goal: 'Land GTM Engineer / Growth Architect / Automation Specialist role. Target $5000/month',\n  company: 'Building VysionAI \u2014 AI automation agency',\n  background: '7 years PM at Axis Bank, MBA IIT Kharagpur. First marketing hire at Lets Hang \u2014 690 leads at $0.08/lead, 5 n8n workflows, full lifecycle automation.',\n  active_projects: 'n8n workflows on Hostinger VPS, voice agent Mona via Millis AI, SaaS cost calculator, Reddit ICP research agent, newsletter + YouTube intelligence system',\n  tools: 'n8n, Make.com, Clay, Apollo, HubSpot, OpenRouter, Claude, Bolt, Netlify',\n  interests: 'AI tools and use cases, GTM systems, PLG, outbound automation, lifecycle marketing, content systems, how companies hire GTM roles, SaaS trends, automation workflows, n8n builds',\n  score_80_plus: 'directly actionable \u2014 GTM workflow idea, AI tool announcement, hiring signal, outbound tactic, automation system I can build or use now',\n  score_50_79: 'useful background \u2014 market trends, strategic framing, good content angle',\n  score_below_50: 'not relevant \u2014 motivational fluff, personal news, unrelated industry'\n};\nconst rawData = $input.first().json;\nconst posts = Array.isArray(rawData) ? rawData : $input.all().map(function(i) { return i.json; });\nconst results = [];\nfor (const postData of posts) {\n  if (!postData || typeof postData !== 'object') continue;\n  const postedDate = postData.postedAt && postData.postedAt.date ? new Date(postData.postedAt.date) : null;\n  if (!postedDate || postedDate < fromDate) continue;\n  const postText = postData.content || '';\n  const repostText = (postData.repost && postData.repost.content) ? postData.repost.content : '';\n  results.push({ json: {\n    post_id: String(postData.id || postData.entityId || ''),\n    creator_name: creatorMeta.creator_name,\n    creator_url: creatorMeta.profile_url,\n    post_url: postData.linkedinUrl || '',\n    post_text: postText.substring(0, 5000),\n    repost_text: repostText.substring(0, 2000),\n    post_type: postData.type || 'post',\n    posted_date: postData.postedAt && postData.postedAt.date ? postData.postedAt.date : '',\n    likes: (postData.engagement && postData.engagement.likes) ? postData.engagement.likes : 0,\n    comments: (postData.engagement && postData.engagement.comments) ? postData.engagement.comments : 0,\n    shares: (postData.engagement && postData.engagement.shares) ? postData.engagement.shares : 0,\n    text_for_scoring: (postText + ' ' + repostText).trim().substring(0, 2000),\n    my_context: JSON.stringify(MY_CONTEXT)\n  }});\n}\nreturn results;"
      },
