      "parameters": {
        "jsCode": "const configRow = $('Read Config Sheet').first().json;\nconst lastScrapedDate = (configRow.value || '2026-01-01').toString().split('T')[0];\nconst creators = $input.all().map(function(item) { return item.json; });\nconst today = new Date().toISOString().split('T')[0];\nreturn creators\n  .filter(function(c) { return c.creator_name && c.profile_url; })\n  .map(function(c) {\n    const typeRaw = (c.type || '').toString().trim().toLowerCase();\n    const fromDate = typeRaw === 'new' ? '2026-01-01' : lastScrapedDate;\n    return { json: {\n      creator_name: c.creator_name, profile_url: c.profile_url,\n      type: typeRaw, from_date: fromDate, to_date: today, niche: c.niche || ''\n    }};\n  });"
      },
