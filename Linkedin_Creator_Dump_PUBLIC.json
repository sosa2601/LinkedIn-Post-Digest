        "jsCode": "const allRows = $input.all();\nlet maxDate = null;\nfor (const row of allRows) {\n  const val = row.json && row.json.scraped_at ? row.json.scraped_at : null;\n  if (!val) continue;\n  const d = new Date(val);\n  if (!isNaN(d.getTime()) && (!maxDate || d > maxDate)) {\n    maxDate = d;\n  }\n}\nif (!maxDate) throw new Error('No valid scraped_at values found in LinkedIn_Dump sheet');\nconst dateStr = maxDate.toISOString().split('T')[0];\nreturn [{ json: { last_scraped_date: dateStr } }];"
